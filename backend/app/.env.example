# Copy to ../../lma.env (repo root) and edit. Loaded by backend/run.sh.
# Knowledge sources are configured separately in sources.yaml (see
# sources.example.yaml at the repo root).

# Identity / deployment
USER_NAME=Your Name
# USER_CONTEXT=one-liner about you, woven into the suggestion prompt
# LMA_PUBLIC_URL=https://your-host.example:8443/   # shown in HTTPS hints

# LLM provider: claude-cli | anthropic-api | ollama-cloud | ollama-local |
#               openai-compatible | custom-command
LLM_PROVIDER=claude-cli
# claude-cli: requires `claude` installed + logged in on this host (subscription)
# CLAUDE_BIN=claude
# SUGGEST_MODEL=sonnet
# SUGGEST_EFFORT=low
# DEEP_MODEL=sonnet
# DEEP_EFFORT=medium
# anthropic-api:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
# ollama-cloud (hosted big open models; key from https://ollama.com):
# OLLAMA_CLOUD_API_KEY=...
# OLLAMA_CLOUD_MODEL=glm-4.6
# ollama-local (fully private; ollama serve on this host or nearby):
# OLLAMA_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_LOCAL_MODEL=llama3.3
# openai-compatible (OpenRouter, LM Studio, vLLM, any other endpoint):
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=llama3.3
# custom-command (any shell command: prompt on stdin, reply on stdout,
# system prompt in $LLM_SYSTEM_PROMPT, $LLM_FAST=1 for the quick loop):
# CUSTOM_LLM_CMD=my-llm-wrapper --json

# Server
LMA_HOST=0.0.0.0
LMA_PORT=5005

# Whisper (faster-whisper)
WHISPER_MODEL=small.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
# WHISPER_LANGUAGE=en
# WHISPER_BEAM_SIZE=1

# RAG retrieval
# QDRANT_URL=http://127.0.0.1:6333
# RAG_ENABLED=true
# RAG_COLLECTION=lma_knowledge
# RAG_TOP_K=5
# RAG_MIN_SCORE=0.45

# Suggestion cadence
# SUGGEST_MIN_INTERVAL_S=12
# SUGGEST_MIN_NEW_CHARS=120

# Speaker verification (in-person mode)
# SPEAKER_DEVICE=cpu
# SPEAKER_THRESHOLD=0.40
# ENROLL_TARGET_S=20

# Energy-VAD endpointing
# VAD_THRESHOLD=0.008
# ENDPOINT_SILENCE_MS=800
# MIN_UTT_MS=350
# MAX_UTT_MS=15000
# PREROLL_MS=250

# Echo suppression (online mode)
# ECHO_SUPPRESS=true
# ECHO_WINDOW_S=12
# ECHO_SIMILARITY=0.82
